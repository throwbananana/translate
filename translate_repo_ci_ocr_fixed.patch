 #! python
 # -*- coding: utf-8 -*-
+
 """
 语法检查脚本
-检查 book_translator_gui.pyw 是否有语法错误
+
+改进点：
+- 检查整个项目中的 .py / .pyw 文件，而不是只检查 GUI 单文件
+- 跳过常见的运行态目录与虚拟环境目录
 """
 
+from pathlib import Path
 import py_compile
 import sys
 
-try:
-    py_compile.compile('book_translator_gui.pyw', doraise=True)
-    print("✓ 语法检查通过！")
-    print("✓ 没有发现语法错误")
-    sys.exit(0)
-except py_compile.PyCompileError as e:
-    print("✗ 发现语法错误:")
-    print(str(e))
-    sys.exit(1)
+EXCLUDED_PARTS = {
+    '.git',
+    '.github',
+    '.pytest_cache',
+    '__pycache__',
+    '.venv',
+    'venv',
+    'build',
+    'dist',
+}
+
+
+def should_skip(path: Path) -> bool:
+    return any(part in EXCLUDED_PARTS for part in path.parts)
+
+
+def iter_python_files(root: Path):
+    for path in root.rglob('*'):
+        if path.suffix.lower() not in {'.py', '.pyw'}:
+            continue
+        if should_skip(path):
+            continue
+        yield path
+
+
+def main() -> int:
+    root = Path(__file__).resolve().parent
+    failed = []
+    checked = 0
+
+    for path in iter_python_files(root):
+        checked += 1
+        try:
+            py_compile.compile(str(path), doraise=True)
+        except py_compile.PyCompileError as exc:
+            failed.append((path, str(exc)))
+
+    if failed:
+        print("✗ 发现语法错误:\n")
+        for path, message in failed:
+            print(f"- {path}:\n{message}\n")
+        return 1
+
+    print(f"✓ 语法检查通过！共检查 {checked} 个 Python 文件")
+    return 0
+
+
+if __name__ == '__main__':
+    sys.exit(main())
