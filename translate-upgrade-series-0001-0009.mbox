+from export_helpers import (
+    build_translation_output_name,
+    sanitize_language_label,
+    write_utf8_text,
+    export_analysis_text_file,
+)
+
+
+def test_sanitize_language_label_replaces_invalid_chars():
+    assert sanitize_language_label('中/文:*?') == '中_文___'
+
+
+def test_build_translation_output_name_uses_original_stem():
+    name = build_translation_output_name('docs/sample_book.epub', '中文', '.txt')
+    assert name == 'sample_book_中文译文.txt'
+
+
+def test_write_utf8_text_roundtrip(tmp_path):
+    path = tmp_path / 'out.txt'
+    write_utf8_text(path, 'hello')
+    assert path.read_text(encoding='utf-8') == 'hello'
+
+
+def test_export_analysis_text_file_contains_section_headers(tmp_path):
+    path = tmp_path / 'analysis.txt'
+    export_analysis_text_file(path, ['原文'], ['译文'], ['解析'])
+    content = path.read_text(encoding='utf-8')
+    assert '书籍翻译工具 - 段落解析结果' in content
+    assert '【原文】' in content
+    assert '【解析】' in content
