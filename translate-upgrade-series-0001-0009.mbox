+from ui_view_helpers import (
+    build_original_text_display,
+    build_file_info_label,
+    get_preview_toggle_button_text,
+)
+
+
+def test_build_original_text_display_returns_preview_for_large_files():
+    text = "a" * 120
+    result = build_original_text_display(text, preview_limit=50, show_full_text=False)
+    assert "预览模式" in result
+    assert len(result) > 50
+
+
+def test_build_original_text_display_returns_full_text_when_enabled():
+    text = "abcdef"
+    result = build_original_text_display(text, preview_limit=3, show_full_text=True)
+    assert result == "abcdef"
+
+
+def test_build_file_info_label_changes_with_mode():
+    assert "仅显示前" in build_file_info_label(100, 50, False)
+    assert "显示完整文件" in build_file_info_label(100, 50, True)
+    assert "已加载完整文件" in build_file_info_label(20, 50, False)
+
+
+def test_get_preview_toggle_button_text_matches_state():
+    assert get_preview_toggle_button_text(True) == "仅显示预览"
+    assert get_preview_toggle_button_text(False) == "显示完整原文"
