@@ -0,0 +1,71 @@
+#! python
+# -*- coding: utf-8 -*-
+"""纯函数级别的提示词与结构化输出辅助工具。
+
+这些函数不依赖 GUI 状态，适合逐步从超大 GUI 文件中抽离，
+便于单元测试与后续模块化重构。
+"""
+
+from __future__ import annotations
+
+import json
+import re
+from typing import Any, Dict
+
+
+def build_analysis_prompt(source_text: str, translated_text: str, target_language: str) -> str:
+    """构建段落解析提示词。"""
+    return f"""请对以下翻译内容进行详细解析和讲解。
+
+【原文】
+{source_text}
+
+【译文】
+{translated_text}
+
+请从以下角度进行解析：
+1. 内容概要：简要概括这段文字的主要内容
+2. 关键信息：指出其中的关键概念、人物、事件或论点
+3. 翻译说明：如有特殊术语或表达，说明翻译的处理方式
+4. 延伸思考：提供相关的背景知识或思考角度
+
+请用{target_language}回答。"""
+
+
+def build_book_metadata_prompt(preview_text: str) -> str:
+    """构建图书元数据自动识别提示词。"""
+    return (
+        "你是一个专业的图书管理员。请分析以下书籍片段，并提取元数据。\n"
+        "请严格返回 JSON 格式，包含以下字段：\n"
+        "- title: 书名 (如果无法确定，根据内容拟定)\n"
+        "- author: 作者 (如果未知，填 'Unknown')\n"
+        "- description: 200字以内的精彩简介，包含核心主题、风格和亮点。\n"
+        "\n"
+        f"书籍片段：\n{preview_text}..."
+    )
+
+
+def extract_first_json_object(text: str) -> Dict[str, Any]:
+    """从模型输出中提取第一个 JSON 对象。
+
+    支持输出前后带有说明文字或 Markdown 代码块的常见场景。
+    """
+    if not text or not text.strip():
+        raise ValueError("empty response")
+
+    cleaned = text.strip()
+    cleaned = re.sub(r"^```(?:json)?\s*", "", cleaned, flags=re.IGNORECASE)
+    cleaned = re.sub(r"\s*```$", "", cleaned)
+
+    match = re.search(r"\{.*\}", cleaned, re.DOTALL)
+    if not match:
+        raise ValueError("no json object found in response")
+
+    return json.loads(match.group(0))
