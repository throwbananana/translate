+#! python
+# -*- coding: utf-8 -*-
+"""在线书城 / 社区图书馆 UI 数据辅助工具。
+
+目标：
+- 抽离搜索结果分组与 TreeView 行数据构造
+- 抽离详情文本格式化
+- 不触碰真实网络请求与 GUI 事件绑定
+"""
+
+from __future__ import annotations
+
+
+def group_results_by_category(results, default_category="Uncategorized"):
+    grouped = {}
+    for res in results:
+        cat = res.get("category", default_category)
+        if cat not in grouped:
+            grouped[cat] = []
+        grouped[cat].append(res)
+    return grouped
+
+
+def build_tree_rows_for_results(grouped_results, row_prefix="search"):
+    rows = []
+    for i, (cat, cat_books) in enumerate(grouped_results.items()):
+        parent_row = {
+            "iid": f"{row_prefix}_cat_{i}",
+            "values": ("📂 " + cat, "", "", "", "", "", "分类"),
+        }
+        children = []
+        for j, res in enumerate(cat_books):
+            children.append({
+                "iid": f"{row_prefix}_book_{i}_{j}",
+                "values": (
+                    res.get("title", "未知"),
+                    res.get("author", "未知"),
+                    res.get("language", ""),
+                    res.get("extension", ""),
+                    res.get("size", ""),
+                    res.get("source", ""),
+                    cat,
+                ),
+            })
+        rows.append((parent_row, children))
+    return rows
+
+
+def find_result_by_title(results, title):
+    for res in results:
+        if res.get("title") == title:
+            return res
+    return None
+
+
+def format_search_result_detail(result):
+    return (
+        f"标题: {result.get('title')}\n"
+        f"作者: {result.get('author')}\n"
+        f"分类: {result.get('category', 'Uncategorized')}\n"
+        f"格式: {result.get('extension')} | 大小: {result.get('size')} | 语言: {result.get('language')}\n"
+        f"来源: {result.get('source')}\n"
+        f"详情: {result.get('metadata', '')}"
+    )
+
+
+def build_category_rows(books):
+    rows = []
+    for book in books:
+        rows.append({
+            "title": book.get("title", "Unknown"),
+            "author": book.get("author", "Unknown"),
+            "description": book.get("description", ""),
+            "uploader": book.get("uploader", "Anon"),
+            "size": book.get("size", ""),
+            "date": book.get("date", ""),
+            "url": book.get("url", ""),
+        })
+    return rows
