new file mode 100644
--- /dev/null
+++ b/runtime_state_helpers.py
@@ -0,0 +1,75 @@
+#! python
+# -*- coding: utf-8 -*-
+"""运行时状态持久化辅助工具。
+
+目标：
+- 统一批量任务与进度缓存的 JSON 读写
+- 抽离 payload 组装逻辑，减轻 GUI 主文件复杂度
+"""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+from typing import Any
+
+
+def load_json_state(path: str | Path, default: Any):
+    """读取 JSON 状态文件；文件不存在时返回默认值。"""
+    path = Path(path)
+    if not path.exists():
+        return default
+
+    with open(path, 'r', encoding='utf-8') as f:
+        return json.load(f)
+
+
+def save_json_state(path: str | Path, data: Any, indent: int | None = 2):
+    """保存 JSON 状态文件。"""
+    path = Path(path)
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with open(path, 'w', encoding='utf-8') as f:
+        json.dump(data, f, ensure_ascii=False, indent=indent)
+
+
+def remove_state_file(path: str | Path):
+    """删除状态文件（如果存在）。"""
+    path = Path(path)
+    if path.exists():
+        path.unlink()
+
+
+def build_progress_cache_payload(
+    file_path: str,
+    signature: str,
+    source_segments: list,
+    translated_segments: list,
+    failed_segments: list,
+    lm_studio_fallback_active: bool,
+    target_language: str,
+):
+    """构建翻译进度缓存 payload。"""
+    if not file_path or not source_segments:
+        return None
+
+    return {
+        'file_path': file_path,
+        'signature': signature,
+        'source_segments': source_segments,
+        'translated_segments': translated_segments,
+        'failed_segments': failed_segments,
+        'lm_studio_fallback_active': lm_studio_fallback_active,
+        'target_language': target_language,
+        'resume_from_index': len(translated_segments),
+    }
+
+
+def resume_cache_matches_signature(cache: dict, current_signature: str) -> bool:
+    """判断缓存签名是否与当前文件内容匹配。"""
+    if not isinstance(cache, dict):
+        return False
+    return cache.get('signature') == current_signature
diff --git a/tests/test_runtime_state_helpers.py b/tests/test_runtime_state_helpers.py
new file mode 100644
--- /dev/null
+++ b/tests/test_runtime_state_helpers.py
@@ -0,0 +1,49 @@
+from pathlib import Path
+
+from runtime_state_helpers import (
+    build_progress_cache_payload,
+    load_json_state,
+    remove_state_file,
+    resume_cache_matches_signature,
+    save_json_state,
+)
+
+
+def test_save_and_load_json_state_roundtrip(tmp_path):
+    path = tmp_path / "state.json"
+    payload = {"a": 1, "b": ["x", "y"]}
+
+    save_json_state(path, payload)
+    loaded = load_json_state(path, default={})
+
+    assert loaded == payload
+
+
+def test_remove_state_file(tmp_path):
+    path = tmp_path / "state.json"
+    save_json_state(path, {"ok": True})
+    assert path.exists()
+
+    remove_state_file(path)
+
+    assert not path.exists()
+
+
+def test_build_progress_cache_payload_contains_resume_index():
+    payload = build_progress_cache_payload(
+        file_path="sample.txt",
+        signature="sig",
+        source_segments=["a", "b", "c"],
+        translated_segments=["ta", "tb"],
+        failed_segments=[],
+        lm_studio_fallback_active=False,
+        target_language="中文",
+    )
+
+    assert payload["resume_from_index"] == 2
+    assert payload["file_path"] == "sample.txt"
+
+
+def test_resume_cache_matches_signature():
+    assert resume_cache_matches_signature({"signature": "abc"}, "abc") is True
+    assert resume_cache_matches_signature({"signature": "abc"}, "xyz") is False
+    assert resume_cache_matches_signature([], "abc") is False
