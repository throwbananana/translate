+++ b/export_helpers.py
@@ -0,0 +1,125 @@
+#! python
+# -*- coding: utf-8 -*-
+"""导出相关辅助工具。
+
+这些函数尽量保持与 GUI 解耦，专注于文件名生成与导出内容写入。
+"""
+
+from __future__ import annotations
+
+import re
+import uuid
+from pathlib import Path
+
+
+def sanitize_language_label(target_language: str) -> str:
+    label = re.sub(r'[\\/:*?"<>|]', "_", target_language or "")
+    label = label.strip()
+    return label or "译文"
+
+
+def build_translation_output_name(original_file: str, target_language: str, ext: str, suffix: str = "译文") -> str:
+    safe_lang = sanitize_language_label(target_language)
+    if original_file:
+        base_name = Path(original_file).stem
+        return f"{base_name}_{safe_lang}{suffix}{ext}"
+    return f"{safe_lang}{suffix}{ext}"
+
+
+def write_utf8_text(path: str | Path, text: str):
+    path = Path(path)
+    with open(path, 'w', encoding='utf-8') as f:
+        f.write(text)
+
+
+def export_analysis_text_file(file_path: str | Path, source_segments: list, translated_segments: list, analysis_segments: list):
+    file_path = Path(file_path)
+    with open(file_path, 'w', encoding='utf-8') as f:
+        f.write("=" * 60 + "\n")
+        f.write("书籍翻译工具 - 段落解析结果\n")
+        f.write("=" * 60 + "\n\n")
+
+        for i, (source, translated, analysis) in enumerate(zip(source_segments, translated_segments, analysis_segments)):
+            f.write(f"{'='*40}\n")
+            f.write(f"段落 {i+1}\n")
+            f.write(f"{'='*40}\n\n")
+            f.write(f"【原文】\n{source}\n\n")
+            f.write(f"【译文】\n{translated}\n\n")
+            f.write(f"【解析】\n{analysis if analysis else '（未解析）'}\n\n")
+
+
+def export_bilingual_docx_file(filename: str | Path, source_segments: list, translated_segments: list):
+    from docx import Document
+
+    doc = Document()
+    doc.add_heading('双语对照翻译 / Bilingual Translation', 0)
+
+    table = doc.add_table(rows=1, cols=2)
+    table.style = 'Table Grid'
+    hdr_cells = table.rows[0].cells
+    hdr_cells[0].text = '原文 (Original)'
+    hdr_cells[1].text = '译文 (Translation)'
+
+    limit = max(len(source_segments), len(translated_segments))
+    for i in range(limit):
+        row_cells = table.add_row().cells
+        if i < len(source_segments):
+            row_cells[0].text = source_segments[i]
+        if i < len(translated_segments):
+            row_cells[1].text = translated_segments[i]
+
+    doc.save(str(filename))
+
+
+def export_bilingual_epub_file(
+    file_path: str | Path,
+    original_file: str,
+    target_language: str,
+    source_segments: list,
+    translated_segments: list,
+    epub_module,
+):
+    book = epub_module.EpubBook()
+
+    title = Path(original_file).stem if original_file else "Translation"
+    book.set_identifier(str(uuid.uuid4()))
+    book.set_title(f"{title} (双语版)")
+    book.set_language(target_language)
+    book.add_author("Book Translator AI")
+
+    chapters = []
+    chunk_size = 50
+    total_segments = len(source_segments)
+
+    style = """
+        body { font-family: sans-serif; }
+        .segment { margin-bottom: 1.5em; border-bottom: 1px dashed #ccc; padding-bottom: 1em; }
+        .original { color: #666; font-size: 0.9em; margin-bottom: 0.5em; }
+        .translation { color: #000; font-size: 1.0em; font-weight: bold; }
+    """
+    css_item = epub_module.EpubItem(uid="style_nav", file_name="style/nav.css", media_type="text/css", content=style)
+    book.add_item(css_item)
+
+    for i in range(0, total_segments, chunk_size):
+        chunk_source = source_segments[i:i+chunk_size]
+        chunk_trans = list(translated_segments[i:i+chunk_size])
+
+        if len(chunk_trans) < len(chunk_source):
+            chunk_trans.extend([""] * (len(chunk_source) - len(chunk_trans)))
+
+        html_content = [f"<h1>第 {i // chunk_size + 1} 部分</h1>"]
+        for src, trans in zip(chunk_source, chunk_trans):
+            src_html = src.replace("\n", "<br/>")
+            trans_html = trans.replace("\n", "<br/>")
+            html_content.append(f"""
+            <div class="segment">
+                <div class="original">{src_html}</div>
+                <div class="translation">{trans_html}</div>
+            </div>
+            """)
+
+        chapter = epub_module.EpubHtml(title=f"Part {i // chunk_size + 1}", file_name=f"part_{i // chunk_size + 1}.xhtml", lang='zh')
+        chapter.content = "".join(html_content)
+        chapter.add_item(css_item)
+        book.add_item(chapter)
+        chapters.append(chapter)
+
+    book.toc = tuple(chapters)
+    book.add_item(epub_module.EpubNcx())
+    book.add_item(epub_module.EpubNav())
+    book.spine = ['nav'] + chapters
+    epub_module.write_epub(str(file_path), book, {})
