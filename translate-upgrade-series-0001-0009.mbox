@@ -0,0 +1,95 @@
+#! python
+# -*- coding: utf-8 -*-
+"""API 选择与分发辅助工具。
+
+这些函数尽量保持无状态，便于从 GUI 中逐步抽离选择逻辑。
+"""
+
+from __future__ import annotations
+
+from typing import Callable, Dict, Iterable
+
+
+def map_api_name_to_key(api_name: str, custom_local_models: Dict[str, Dict]) -> str:
+    """将 UI 显示名称映射为内部 API 键。"""
+    if not api_name:
+        return "gemini"
+
+    if api_name.startswith("[本地] "):
+        display_name = api_name[5:]
+        for key, config in custom_local_models.items():
+            if config.get('display_name') == display_name:
+                return key
+
+    api_map = {
+        "Gemini API": "gemini",
+        "OpenAI API": "openai",
+        "Claude API": "claude",
+        "DeepSeek API": "deepseek",
+        "本地 LM Studio": "lm_studio",
+        "自定义API": "custom",
+    }
+    return api_map.get(api_name, "gemini")
+
+
+def is_api_ready(
+    api_type: str,
+    custom_local_models: Dict[str, Dict],
+    api_configs: Dict[str, Dict],
+    openai_support: bool,
+) -> bool:
+    """判断指定 API / 本地模型是否具备调用条件。"""
+    if api_type in custom_local_models:
+        config = custom_local_models.get(api_type, {})
+        return bool(config.get('base_url') and config.get('model_id'))
+
+    config = api_configs.get(api_type, {})
+    if not config:
+        return False
+
+    if api_type == 'custom':
+        return bool(config.get('base_url') and config.get('model'))
+    if api_type == 'lm_studio':
+        return openai_support and bool(config.get('base_url') and config.get('model'))
+
+    return bool(config.get('api_key') and config.get('model'))
+
+
+def get_preferred_text_api(
+    candidate_api_types: Iterable[str],
+    custom_local_models: Dict[str, Dict],
+    api_configs: Dict[str, Dict],
+    openai_support: bool,
+) -> str:
+    """从候选列表中选择第一个可用的文本生成 API。"""
+    for api_type in candidate_api_types:
+        if api_type and is_api_ready(api_type, custom_local_models, api_configs, openai_support):
+            return api_type
+
+    raise ValueError("未找到可用的文本生成 API，请先配置解析 API 或翻译 API")
+
+
+def select_text_generation_handler(
+    api_type: str,
+    custom_local_models: Dict[str, Dict],
+    builtin_handlers: Dict[str, Callable[[str], str]],
+    custom_local_handler_factory: Callable[[str], Callable[[str], str]],
+) -> Callable[[str], str]:
+    """根据 API 类型返回对应的文本生成处理器。"""
+    if api_type in custom_local_models:
+        return custom_local_handler_factory(api_type)
+
+    handler = builtin_handlers.get(api_type)
+    if handler is None:
+        raise ValueError(f"不支持的文本生成 API 类型: {api_type}")
+
+    return handler
