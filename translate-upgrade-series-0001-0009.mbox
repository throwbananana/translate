new file mode 100644
--- /dev/null
+++ b/ui_view_helpers.py
@@ -0,0 +1,86 @@
+#! python
+# -*- coding: utf-8 -*-
+"""UI 视图辅助工具。
+
+目标：
+- 抽离原文预览/完整显示的文案拼装
+- 抽离主题切换中的重复样式代码
+"""
+
+from __future__ import annotations
+
+
+def build_original_text_display(current_text: str, preview_limit: int, show_full_text: bool) -> str:
+    """构建原文区域显示内容。"""
+    char_count = len(current_text)
+    is_large_file = char_count > preview_limit
+
+    if is_large_file and not show_full_text:
+        preview_text = current_text[:preview_limit]
+        preview_text += f"\n\n{'='*60}\n"
+        preview_text += f"⚠️ 预览模式：仅显示前 {preview_limit:,} / {char_count:,} 字符\n"
+        preview_text += "点击上方'显示完整原文'按钮查看全文\n"
+        preview_text += f"{'='*60}"
+        return preview_text
+
+    return current_text
+
+
+def build_file_info_label(char_count: int, preview_limit: int, show_full_text: bool) -> str:
+    """构建文件信息标签。"""
+    if char_count > preview_limit:
+        if show_full_text:
+            return f"✓ 显示完整文件 ({char_count:,} 字符)"
+        return f"⚠️ 大文件 ({char_count:,} 字符) - 仅显示前 {preview_limit:,} 字符"
+    return f"✓ 已加载完整文件 ({char_count:,} 字符)"
+
+
+def get_preview_toggle_button_text(show_full_text: bool) -> str:
+    return "仅显示预览" if show_full_text else "显示完整原文"
+
+
+def apply_dark_theme(style, text_widgets, listboxes):
+    style.theme_use('clam')
+
+    bg_color = "#2b2b2b"
+    fg_color = "#ffffff"
+    field_bg = "#3c3f41"
+    select_bg = "#005fb8"
+
+    style.configure(".", background=bg_color, foreground=fg_color)
+    style.configure("TLabel", background=bg_color, foreground=fg_color)
+    style.configure("TButton", background=field_bg, foreground=fg_color, borderwidth=1)
+    style.map("TButton", background=[("active", "#4c5052")])
+    style.configure("TEntry", fieldbackground=field_bg, foreground=fg_color)
+    style.configure("TCombobox", fieldbackground=field_bg, foreground=fg_color, background=bg_color)
+    style.configure("Treeview", background=field_bg, foreground=fg_color, fieldbackground=field_bg)
+    style.map("Treeview", background=[("selected", select_bg)])
+    style.configure("TLabelframe", background=bg_color, foreground=fg_color)
+    style.configure("TLabelframe.Label", background=bg_color, foreground=fg_color)
+
+    for widget in text_widgets:
+        try:
+            widget.config(bg=field_bg, fg=fg_color, insertbackground=fg_color)
+        except Exception:
+            pass
+
+    for lb in listboxes:
+        try:
+            lb.config(bg=field_bg, fg=fg_color)
+        except Exception:
+            pass
+
+
+def apply_light_theme(style, text_widgets, listboxes):
+    style.theme_use('default')
+
+    for widget in text_widgets:
+        try:
+            widget.config(bg="white", fg="black", insertbackground="black")
+        except Exception:
+            pass
+
+    for lb in listboxes:
+        try:
+            lb.config(bg="white", fg="black")
+        except Exception:
+            pass
