+from pathlib import Path
+import py_compile
+
+
+PROJECT_ROOT = Path(__file__).resolve().parents[1]
+
+
+def test_core_python_files_compile():
+    targets = [
+        PROJECT_ROOT / 'book_translator_gui.pyw',
+        PROJECT_ROOT / 'config_manager.py',
+        PROJECT_ROOT / 'file_processor.py',
+        PROJECT_ROOT / 'translation_engine.py',
+        PROJECT_ROOT / 'translation_memory.py',
+    ]
+
+    missing = [str(path) for path in targets if not path.exists()]
+    assert not missing, f"Missing expected files: {missing}"
+
+    for path in targets:
+        py_compile.compile(str(path), doraise=True)
+
+
+def test_runtime_artifacts_are_gitignored():
+    gitignore = (PROJECT_ROOT / '.gitignore').read_text(encoding='utf-8')
+
+    assert 'translator_config.json' in gitignore
+    assert 'translation_memory.db' in gitignore
+    assert '*.db' in gitignore
